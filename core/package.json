{
  "name": "@cuan/core",
  "version": "0.0.0",
  "private": true,
  "description": "Cuan backend API powered by Elysia.js",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "typecheck": "tsc --noEmit",
    "test": "OPENMODEL_BASE_URL=http://localhost:3999 bash scripts/test-with-db.sh",
    "db:reset": "bash scripts/reset-dev-db.sh",
    "db:generate-auth": "better-auth generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:seed": "bun run scripts/seed.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.86",
    "@ai-sdk/openai": "^3.0.74",
    "ai": "^6.0.209",
    "better-auth": "^1.6.20",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.29",
    "logixlysia": "^6.5.1",
    "pg": "^8.22.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.21",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "pino": "^10.3.1"
  }
}
